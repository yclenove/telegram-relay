# 复制本文件为 .env 并填写真实值（.env 禁止提交仓库）
# 启动 relay 时若当前工作目录存在 .env，会自动加载。
#
# AUTH_TOKEN / JWT_SECRET 随机串可本地生成（勿泄露）：
#   Windows：pwsh -File scripts/generate-env-secrets.ps1
#   Linux/Mac：bash scripts/generate-env-secrets.sh

# 入站鉴权（必填）：外部 POST /api/v1|v2/notify 的 Authorization: Bearer 与此完全一致
AUTH_TOKEN=replace-with-long-random-token

# 管理端 JWT 签名密钥（必填）：至少 32 字符；与 AUTH_TOKEN 用途不同，勿混用
JWT_SECRET=replace-with-jwt-secret-at-least-32-chars
BOOTSTRAP_PASSWORD=replace-strong-admin-password
# 若曾用旧密码启动过，改 BOOTSTRAP_PASSWORD 后仍 401：可临时设为 true 启动一次以把库中 admin 密码同步为上面新值，然后改回 false
BOOTSTRAP_PASSWORD_SYNC=false

# Telegram（必填；占位值仅用于本地联调，worker 发消息会失败）
TELEGRAM_BOT_TOKEN=123456:replace-from-botfather
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# 可选：经本地代理访问 Telegram（如 v2rayN HTTP 常为 10809，SOCKS5 为 socks5://127.0.0.1:10808）
#TELEGRAM_PROXY=http://127.0.0.1:10809

# 数据库：可只填 PG_*（未设 DATABASE_DSN 时程序会自动拼接），或直接写整串 DSN
# DATABASE_DSN=postgres://user:pass@127.0.0.1:5432/telegram?sslmode=disable
#
# 若启动报 permission denied for schema public（PG15+ 或云库常见）：请库管执行其一
#   GRANT USAGE, CREATE ON SCHEMA public TO 你的数据库用户;
# 或由库管创建专用模式并授权后，在此指定（表与迁移将建在该模式下，勿与别的应用共用一个模式名）：
# PG_SCHEMA=telegram_relay
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=telegram

# 可选：HTTP 监听地址；不设时程序默认 :8780（避免与本机 8080 冲突）
# LISTEN_ADDR=:8780

# 可选：管理台静态资源目录（telegram-relay-admin 的 npm run build 产物目录 admin-dist；留空则不挂载管理台 SPA，仅 API）
# 与宝塔文档一致时可填，例如：ADMIN_STATIC_DIR=/www/wwwroot/telegram-relay/admin-dist
#ADMIN_STATIC_DIR=/www/wwwroot/telegram-relay/admin-dist

# 可选：对外公网 HTTPS 根地址（无尾斜杠），用于管理台生成「第三方接入文档」中的 notify URL；不设时可在弹窗中手动填写 base_url
# PUBLIC_BASE_URL=https://relay.example.com
