# 复制本文件为 .env 并填写真实值（.env 禁止提交仓库）
# 启动 relay 时若当前工作目录存在 .env，会自动加载。

# 入站鉴权（必填）
AUTH_TOKEN=replace-with-long-random-token

# 管理端 JWT 与首次管理员（必填）
JWT_SECRET=replace-with-jwt-secret-at-least-32-chars
BOOTSTRAP_PASSWORD=replace-strong-admin-password
# 若曾用旧密码启动过，改 BOOTSTRAP_PASSWORD 后仍 401：可临时设为 true 启动一次以把库中 admin 密码同步为上面新值，然后改回 false
BOOTSTRAP_PASSWORD_SYNC=false

# Telegram（必填；占位值仅用于本地联调，worker 发消息会失败）
TELEGRAM_BOT_TOKEN=123456:replace-from-botfather
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# 可选：经本地代理访问 Telegram（如 v2rayN HTTP 常为 10809，SOCKS5 为 socks5://127.0.0.1:10808）
#TELEGRAM_PROXY=http://127.0.0.1:10809

# 数据库：可只填 PG_*（未设 DATABASE_DSN 时程序会自动拼接），或直接写整串 DSN
# DATABASE_DSN=postgres://user:pass@127.0.0.1:5432/telegram?sslmode=disable
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=telegram

# 可选：HTTP 监听地址；不设时程序默认 :8780（避免与本机 8080 冲突）
# LISTEN_ADDR=:8780
